.vscode/
# PyCharm ayarları
.idea/

# --- İşletim Sistemi Kalıntıları ---
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
# macOS (olur da ileride Mac'te açarsan)
.DS_Store

# --- Projeye Özel Çıktılar (Gelecek İçin) ---
